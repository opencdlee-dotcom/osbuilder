# OSBuilder default — Node + pnpm CI workflow (SCL-04)
# Source: pnpm/action-setup README + actions/setup-node (verified 2026-05-01)
# CRITICAL: pnpm/action-setup MUST precede actions/setup-node so cache: 'pnpm' engages.
name: Test on PR

on:
  pull_request:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6

      - uses: pnpm/action-setup@v4
        with:
          version: 10

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'pnpm'

      - run: pnpm install --frozen-lockfile
      - run: pnpm test
