# OSBuilder common .gitignore
# Source: github.com/github/gitignore (curated)

# Env files — block real secrets, allow example
.env
.env.*
!.env.example
!.env.sample

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# IDE cruft
.vscode/
.idea/
*.swp
*.swo
*~
